{
  "_schema": {
    "description": "videoId -> キュレーション層。fetch-archive.ts は触らない。",
    "structure": {
      "videos.<videoId>._inferred": "infer-curated.ts が自動生成。再実行で上書き。手動で編集しないこと。",
      "videos.<videoId>.<field>": "top-level フィールドは人間が書く。_inferred より優先される。"
    },
    "fields": {
      "category": "ポンコツだいぶ | ポンコツさむらい | ゆるげーむ | こらぼ",
      "game": "Helldivers 2 | Ghost of Yotei | Dave the diver | Planet of Lana | Arise",
      "collabWith": "string[] コラボ相手 (@handle や名前)",
      "episode": "number シリーズ番号",
      "tags": "string[] 自由タグ",
      "kind": "'stream' | 'clip' (raw durationSeconds の自動判定を超える時用)",
      "hidden": "boolean アーカイブから隠す",
      "pinned": "boolean 上位固定",
      "tone": "'coral' | 'lilac' | 'mint' | 'cream' カード配色",
      "memo": "string 自分向けメモ (UI 非表示)"
    }
  },
